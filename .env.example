# API key for the configured LLM provider (Groq, OpenAI, or Google)
AI_API_KEY=your_llm_token_here

# Cloudflare Tunnel token — exposes the local server via a public HTTPS URL
TUNNEL_TOKEN=your_cloudflared_token_here

# Bearer token for the admin console at /admin and all /api/admin/* endpoints
ADMIN_TOKEN=your_admin_api_token_here
